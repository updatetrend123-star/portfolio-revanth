rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (Default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Personal Profile rules
    match /personal/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Projects rules
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Testimonials rules
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Services rules
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. Skills rules
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Experience rules
    match /experience/{expId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. Users rules (Admin Accounts)
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if true; // to bootstrap admin accounts
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
